{
  "name": "jeroendn/ssd",
  "description": "Jeroen's Statistics/Status Dashboard",
  "type": "project",
  "license": "MIT",
  "require": {
    "php": "^8.3",
    "ext-curl": "^8.0",
    "ext-simplexml": "*",
    "guzzlehttp/guzzle": "^7.4",
    "jeroendn/php-helpers": "0.8-beta",
    "jeroendn/php-js-console-logger": "^1.0",
    "jwilsson/spotify-web-api-php": "^5.2"
  },
  "autoload": {
    "psr-4": {
      "SSD\\Integrations\\Spotify\\": "integrations/Spotify/src",
      "SSD\\Integrations\\Steam\\": "integrations/Steam/src",
      "SSD\\Integrations\\UptimeRobot\\": "integrations/UptimeRobot/src",
      "SSD\\Integrations\\Tweakers\\": "integrations/Tweakers/src"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "SSD\\Test\\": "tests/"
    }
  },
  "prefer-stable": true,
  "scripts": {
    "phpunit": "phpunit"
  },
  "config": {
    "sort-packages": true
  },
  "require-dev": {
    "phpunit/phpunit": "^12.5"
  }
}
